  "sync_interval": {
    "auto_sync_enabled": true,
    "interval_minutes": 30,
    "on_startup": true,
    "on_shutdown": true,
    "on_conversation_end": true
  },
  "conflict_resolution": {
    "auto_resolve_enabled": true,
    "strategy": "merge_append",
    "backup_enabled": true
  },
